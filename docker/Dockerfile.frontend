FROM node:18-alpine AS builder

WORKDIR /app

# 复制前端代码
COPY sdpj/ui/webui/frontend/package*.json ./
RUN npm ci

COPY sdpj/ui/webui/frontend/ ./
RUN npm run build

# 生产镜像
FROM nginx:alpine

# 复制构建产物
COPY --from=builder /app/dist /usr/share/nginx/html

# 复制nginx配置
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
