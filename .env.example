# SDPJ-System Environment Variables Example
# Copy this file to .env and modify as needed

# Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
DB_URL=sqlite+aiosqlite:///./sdpj/infrastructure/database/sdpj.db

# Frontend Configuration
VITE_BACKEND_PORT=8000

# Development Configuration
PYTHON_PATH=python
NODE_PATH=node
