# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/db/sdpj.db
SAMPLE_DB_URL=sqlite+aiosqlite:///./data/db/sample.db
RESULT_DB_URL=sqlite+aiosqlite:///./data/db/result.db
USER_DB_URL=sqlite+aiosqlite:///./data/db/user.db

# 生产环境使用PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sdpj

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# 前端配置
FRONTEND_URL=http://localhost:5173

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM API配置
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
QWEN_API_KEY=your-qwen-api-key

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/sdpj.log

# 检测配置
MAX_CONCURRENT_TASKS=10
DETECTION_TIMEOUT=300

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./data/uploads
