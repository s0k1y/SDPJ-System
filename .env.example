# SDPJ-System Environment Variables Example
# Copy this file to .env and modify as needed

# Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
SAMPLE_DB_URL=sqlite+aiosqlite:///./data/db/sample.db
RESULT_DB_URL=sqlite+aiosqlite:///./data/db/result.db
USER_DB_URL=sqlite+aiosqlite:///./data/db/user.db

# Frontend Configuration
VITE_BACKEND_PORT=8000

# Development Configuration
PYTHON_PATH=python
NODE_PATH=node
