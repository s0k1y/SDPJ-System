[flake8]
max-line-length = 120
extend-ignore = D100,D101,D102,D103,D104,D105,D107,D200,D204,D205,D400,E203,W503
per-file-ignores =
    __init__.py:F401
    sdpj/ui/webui/backend/schemas/__init__.py:F401
    sdpj/ui/webui/backend/routers/__init__.py:F401
    sdpj/ui/webui/backend/__init__.py:F401
    sdpj/ui/cli/utils/__init__.py:F401
